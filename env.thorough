# Thorough setup environment — Windows + Linux/WSL
# Usage: load before running the full build & test pipeline
# PowerShell: Get-Content .env.thorough | ForEach-Object { if ($_ -match '^([^#][^=]*)=(.*)$') { [System.Environment]::SetEnvironmentVariable($matches[1].Trim(), $matches[2].Trim()) } }

# --- Windows application ports ---
API_HOST=127.0.0.1
API_PORT=8000
PANEL_HOST=127.0.0.1
PANEL_PORT=8001
REACT_HOST=127.0.0.1
REACT_PORT=8002

# --- Linux / WSL application ports ---
LINUX_API_HOST=127.0.0.1
LINUX_API_PORT=8003
LINUX_PANEL_HOST=127.0.0.1
LINUX_PANEL_PORT=8004
LINUX_REACT_HOST=127.0.0.1
LINUX_REACT_PORT=8005
