# Fast native Windows development environment
# Usage: load before running `uv run python src\main.py`
# PowerShell: Get-Content .env.dev | ForEach-Object { if ($_ -match '^([^#][^=]*)=(.*)$') { [System.Environment]::SetEnvironmentVariable($matches[1].Trim(), $matches[2].Trim()) } }

API_HOST=127.0.0.1
API_PORT=8000
PANEL_HOST=127.0.0.1
PANEL_PORT=8001
REACT_HOST=127.0.0.1
REACT_PORT=8002
